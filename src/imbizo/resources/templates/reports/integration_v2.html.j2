<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Integration v2 Comparison — {{ project.title }}</title>
  <style>
    body { color: #111827; background: #ffffff; font-family: system-ui, sans-serif; line-height: 1.45; margin: 2rem; }
    table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
    th, td { border: 1px solid #4b5563; padding: 0.45rem; text-align: left; vertical-align: top; }
    th { background: #e5e7eb; }
    .methods, .licence-propagation { border: 1px solid #4b5563; background: #f9fafb; padding: 1rem; margin-top: 1rem; }
    @media print { body { margin: 1cm; font-size: 10.5pt; } }
  </style>
</head>
<body>
  <header><h1>Integration v2 Comparison</h1><p>{{ project.title }} — {{ project.date }}</p></header>
  <section>
    <h2>Foreign-stem details</h2>
    <table>
      <thead><tr><th>Stem</th><th>v1.0 score</th><th>v2 score</th><th>Phonological features</th></tr></thead>
      <tbody>
        {% for row in stems %}
          <tr><td>{{ row.surface }}</td><td>{{ row.integration_score }}</td><td>{{ row.phon_integration_score }}</td><td>{{ row.features }}</td></tr>
        {% else %}
          <tr><td colspan="4">No integration v2 scores are available.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  <footer>
    <section class="methods"><h2>Methods note</h2><p>Integration v2 combines morphological and phonological evidence as a transparent, editable score, not an automatic interpretation (Poplack, 1980; Muysken, 2000; Mesthrie, 2002).</p></section>
    {% include "partials/licence_propagation.html.j2" %}
  </footer>
</body>
</html>
