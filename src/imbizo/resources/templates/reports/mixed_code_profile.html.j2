<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Mixed-Code Variety Profile — {{ project.title }}</title>
  <style>
    body { color: #111827; background: #ffffff; font-family: system-ui, sans-serif; line-height: 1.45; margin: 2rem; }
    table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
    th, td { border: 1px solid #4b5563; padding: 0.45rem; text-align: left; vertical-align: top; }
    th { background: #e5e7eb; }
    .caveats, .methods, .licence-propagation { border: 1px solid #4b5563; background: #f9fafb; padding: 1rem; margin-top: 1rem; }
    @media print { body { margin: 1cm; font-size: 10.5pt; } }
  </style>
</head>
<body>
  <header><h1>Mixed-Code Variety Profile</h1><p>{{ project.title }} — {{ project.date }}</p></header>
  <section class="caveats"><h2>Dictionary caveats</h2><p>{{ caveats }}</p></section>
  <section>
    <h2>Span summary</h2>
    <table>
      <thead><tr><th>Variety</th><th>Speaker</th><th>Count</th><th>Duration</th><th>Example</th></tr></thead>
      <tbody>
        {% for row in spans %}
          <tr><td>{{ row.variety }}</td><td>{{ row.speaker_id }}</td><td>{{ row.count }}</td><td>{{ row.duration }}</td><td>{{ row.example }}</td></tr>
        {% else %}
          <tr><td colspan="5">No mixed-code spans are available.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
  <footer>
    <section class="methods"><h2>Methods note</h2><p>Mixed-code evidence is lexical and contextual; it must not be treated as automatic speaker or variety identification (Slabbert &amp; Myers-Scotton, 1997; Hurst, 2008; McCormick, 2002; Mesthrie, 2008).</p></section>
    {% include "partials/licence_propagation.html.j2" %}
  </footer>
</body>
</html>
